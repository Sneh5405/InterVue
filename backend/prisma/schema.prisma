generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      Int           @id @default(autoincrement())
  email                   String        @unique
  name                    String?
  role                    Role          @default(INTERVIEWEE)
  emailVerified           Boolean       @default(false)
  password                String
  status                  UserStatus    @default(ACTIVE)
  emailOtp                EmailOtp?
  interviewsAsHr          Interview[]   @relation("HrInterviews")
  interviewsAsInterviewee Interview[]   @relation("IntervieweeInterviews")
  interviewsAsInterviewer Interview[]   @relation("InterviewerInterviews")
  questionsCreated        Question[]    @relation("CreatedQuestions")
  refreshToken            RefreshToken?
  assessmentsCreated      Assessment[]          @relation("HrAssessments")
  assessmentParticipations AssessmentCandidate[]  @relation("CandidateAssessments")
  submissions             Submission[]
}

model EmailOtp {
  id        Int      @id @default(autoincrement())
  otpHash   String
  expiresAt DateTime
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  device    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id])
}

model Interview {
  id            Int                 @id @default(autoincrement())
  startTime     DateTime
  endTime       DateTime
  status              InterviewStatus     @default(SCHEDULED)
  round               Int                 @default(1)
  meetLink            String?
  hrId                Int
  interviewerId       Int
  intervieweeId       Int
  interviewerAccepted Boolean             @default(false)
  intervieweeAccepted Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  deletedAt           DateTime?
  hr                  User                @relation("HrInterviews", fields: [hrId], references: [id])
  interviewee         User                @relation("IntervieweeInterviews", fields: [intervieweeId], references: [id])
  interviewer         User                @relation("InterviewerInterviews", fields: [interviewerId], references: [id])
  questions           InterviewQuestion[]
}

model Question {
  id            Int                 @id @default(autoincrement())
  text          String
  type          QuestionType
  options       Json?
  correctAnswer String?
  testCases     Json?
  createdById   Int
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  deletedAt     DateTime?
  difficulty    QuestionDifficulty  @default(MEDIUM)
  tags          String[]
  interviews    InterviewQuestion[]
  createdBy     User                @relation("CreatedQuestions", fields: [createdById], references: [id])
  assessments       AssessmentQuestion[]
  assessmentAnswers AssessmentAnswer[]
  submissions       Submission[]
}

model InterviewQuestion {
  id              Int       @id @default(autoincrement())
  order           Int?
  isAsked         Boolean   @default(false)
  feedback        String?
  interviewId     Int
  questionId      Int
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  candidateAnswer String?
  submittedAt     DateTime?
  interview       Interview @relation(fields: [interviewId], references: [id])
  question        Question  @relation(fields: [questionId], references: [id])

  @@unique([interviewId, questionId])
}

enum Role {
  INTERVIEWEE
  INTERVIEWER
  HR
}

enum QuestionType {
  MCQ
  SCENARIO
  CODE
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

enum InterviewStatus {
  PENDING
  SCHEDULED
  COMPLETED
  CANCELLED
  MOVED_TO_NEXT_ROUND
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum AssessmentCandidateStatus {
  INVITED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

model Assessment {
  id             Int      @id @default(autoincrement())
  title          String
  description    String?
  duration       Int      // Duration in minutes
  startTime      DateTime? // Fixed start time
  endTime        DateTime? // Fixed end time
  shareableToken String?   @unique @default(uuid())

  hrId        Int
  hr          User     @relation("HrAssessments", fields: [hrId], references: [id])

  questions   AssessmentQuestion[]
  candidates  AssessmentCandidate[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
}

model AssessmentQuestion {
  id           Int        @id @default(autoincrement())
  assessmentId Int
  assessment   Assessment @relation(fields: [assessmentId], references: [id])
  
  questionId   Int
  question     Question   @relation(fields: [questionId], references: [id])
  
  order        Int?
  points       Int        @default(10)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([assessmentId, questionId])
}

model AssessmentCandidate {
  id           Int        @id @default(autoincrement())
  assessmentId Int
  assessment   Assessment @relation(fields: [assessmentId], references: [id])
  
  candidateId  Int
  candidate    User       @relation("CandidateAssessments", fields: [candidateId], references: [id])
  
  inviteToken  String?    
  status       AssessmentCandidateStatus @default(INVITED)
  
  score        Float?
  startedAt    DateTime?
  completedAt  DateTime?

  answers      AssessmentAnswer[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([assessmentId, candidateId])
}

model AssessmentAnswer {
  id                    Int                 @id @default(autoincrement())
  assessmentCandidateId Int
  assessmentCandidate   AssessmentCandidate @relation(fields: [assessmentCandidateId], references: [id])
  
  questionId            Int
  question              Question            @relation(fields: [questionId], references: [id])
  
  candidateAnswer       String?             // Store Code or MCQ option
  score                 Float?              // Points awarded for this question
  
  submittedAt           DateTime?

  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@unique([assessmentCandidateId, questionId])
}

model Submission {
  id            Int       @id @default(autoincrement())
  code          String
  language      String
  status        String    @default("PENDING") // PENDING, RUNNING, COMPLETED, TIMEOUT, FAILED
  output        String?
  executionTime Float?
  userId        Int
  questionId    Int?
  user          User      @relation(fields: [userId], references: [id])
  question      Question? @relation(fields: [questionId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
